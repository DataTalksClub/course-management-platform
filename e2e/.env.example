# e2e smoke-test configuration. Copy to e2e/.env for local runs, or provide
# these as CI secrets. Never commit real values. The suite also falls back to
# the repo-root .env for DEV_AUTH_TOKEN / PUBLIC_BASE_URL.

# Target deployment (defaults to dev).
E2E_BASE_URL=https://dev.courses.datatalks.club

# Staff API token (Authorization: Token <...>). Falls back to DEV_AUTH_TOKEN
# in the repo-root .env if unset.
E2E_API_TOKEN=

# Admin login (Django admin form login -- NOT OAuth). Must be a staff account.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# Test student. If unset, a per-run student at a Datamailer *mock address*
#   e2e+<namespace>@mailbox.test
# is created admin-side and impersonated via django-loginas. Sends to this
# address are captured by the mock inbox instead of being delivered for real.
E2E_STUDENT_EMAIL=
E2E_STUDENT_PASSWORD=

# Real SES-inbound backend -- the DEFAULT email backend. Datamailer really
# sends via SES and the message is read back from the inbound S3 bucket, so the
# student genuinely receives the email (the usual flow, identical in dev/prod).
# URL = the Datamailer service root (the client appends /api/inbox/...); both
# fall back to DATAMAILER_URL / DATAMAILER_API_KEY in the repo-root .env, so dev
# works with the key already there. The email tests xfail (not fail) when the
# real inbox is unset or REAL_INBOX_ENABLED is off on the target deployment.
E2E_REAL_INBOX_URL=
E2E_REAL_INBOX_API_KEY=
# Real-inbox address shape (must match the datamailer REAL_INBOX_* settings).
E2E_REAL_INBOX_DOMAIN=mailer.dtcdev.click
E2E_REAL_INBOX_TAG=e2e

# Datamailer mock inbox -- opt-in only (@pytest.mark.mock_inbox). It captures
# the send WITHOUT real delivery, so it is no longer the default. URL = the
# Datamailer service root (the client appends /api/mock-inbox/...). Both fall
# back to DATAMAILER_URL / DATAMAILER_API_KEY in the repo-root .env.
E2E_MOCK_INBOX_URL=
E2E_MOCK_INBOX_API_KEY=
# Mock-address shape (must match the datamailer MOCK_INBOX_* settings).
E2E_MOCK_INBOX_DOMAIN=mailbox.test
E2E_MOCK_INBOX_TAG=e2e

# Optional: assert the deployed version matches the just-deployed build.
E2E_EXPECTED_VERSION=

# Tuning.
E2E_HEADLESS=1
E2E_REQUEST_TIMEOUT=30
E2E_UI_TIMEOUT_MS=20000
